{
  "name": "node-ip-ts",
  "version": "1.2.2",
  "author": "Deni Irawan Nugraha <deni.irawan40563@gmail.com>",
  "license": "MIT",
  "homepage": "https://node-ip-ts.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/denycode-dev/ip-ts.git",
    "directory": "packages/ip-ts"
  },
  "keywords": [
    "ip address",
    "ip address library",
    "ip address parser",
    "ip address validator",
    "ip address converter",
    "ip address to buffer",
    "buffer to ip address",
    "ip",
    "address",
    "ipv4",
    "ipv6",
    "subnet",
    "cidr",
    "network",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "description": "Modern TypeScript IP address utility library — ESM, CJS, and browser ready",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "browser": "./dist/esm/index.browser.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/esm/index.browser.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
